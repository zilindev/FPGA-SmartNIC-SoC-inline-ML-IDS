// data_net_2x_plus_1.hex -- Weights for f(x) = 2x + 1
// 3-layer ReLU network with identity layers 1-2, linear output
// For positive x: ReLU passes through, so f(x) = 1.0*(1.0*(2.0*x+0)+0)+1.0 = 2x+1
// Input {1.0, 2.0, 3.0, 4.0} -> output {3.0, 5.0, 7.0, 9.0}
// Expected DMEM[7] = 0x404040A0_40E04110
0000000000000000   // [0] x: placeholder (overwritten by packet DMA)
4000400040004000   // [1] w1: broadcast 2.0
0000000000000000   // [2] b1: broadcast 0.0
3F803F803F803F80   // [3] w2: broadcast 1.0
0000000000000000   // [4] b2: broadcast 0.0
3F803F803F803F80   // [5] w3: broadcast 1.0
3F803F803F803F80   // [6] b3: broadcast 1.0
0000000000000000   // [7] output (cleared)
