sub cmd_bram_write_full {
    my ($addr, $ctrl_hex, $hi_hex, $lo_hex) = @_;
    die "Usage: lab8reg bram_write_full <addr> <ctrl_hex> <hi_hex> <lo_hex>\n"
        unless defined $addr && defined $ctrl_hex && defined $hi_hex && defined $lo_hex;

    my $ctrl = hex($ctrl_hex);
    my $hi = hex($hi_hex);
    my $lo = hex($lo_hex);

    fifo_set_mode(1);
    bram_write($addr + 0, $ctrl & 0xFF, $hi, $lo);
    printf("BRAM[%3d] <= ctrl=0x%02x  data=0x%08x_%08x\n", $addr + 0, $ctrl, $hi, $lo);

    my ($rctrl, $rhi, $rlo) = bram_read($addr + 0);
    printf("Readback:   ctrl=0x%02x  data=0x%08x_%08x\n", $rctrl, $rhi, $rlo);
    fifo_set_mode(0);
}

sub cmd_packet_echo {
    my ($dst_port_hex) = @_;

    print "=== Packet Echo Test ===\n\n";

    # Step 1: Check for packet
    print "1. Checking for packet...\n";
    my $s = regread($STATUS_REG);
    my $pkt_ready = $s & 1;
    my $pkt_word_cnt = ($s >> 24) & 0xFF;
    if (!$pkt_ready) {
        print "   No packet in FIFO. Send a packet from a sub-node first.\n";
        print "   Example: on node0, run: ping -c 1 <fpga_nf2c0_ip>\n";
        return;
    }
    printf("   Packet ready: %d words\n", $pkt_word_cnt);

    # Step 2: Read header
    # NF2.1 header: {dst_port[15:0], word_length[15:0], src_port[15:0], byte_length[15:0]}
    print "2. Reading NF2.1 module header (BRAM[0])...\n";
    fifo_set_mode(1);
    my ($hctrl, $hhi, $hlo) = bram_read(0);
    my $orig_dst = ($hhi >> 16) & 0xFFFF;
    my $word_len = $hhi & 0xFFFF;
    my $src_port = ($hlo >> 16) & 0xFFFF;
    my $byte_len = $hlo & 0xFFFF;
    printf("   ctrl=0x%02x  dst_port=0x%04x  word_len=%d  src_port=0x%04x  byte_len=%d\n",
           $hctrl, $orig_dst, $word_len, $src_port, $byte_len);

    # Decode ports (NF2.1 one-hot: MAC0=0x01, CPU0=0x02, MAC1=0x04, ...)
    my %port_names = (0x01=>"MAC0/nf2c0", 0x02=>"CPU0", 0x04=>"MAC1/nf2c1",
                      0x08=>"CPU1", 0x10=>"MAC2/nf2c2", 0x20=>"CPU2",
                      0x40=>"MAC3/nf2c3", 0x80=>"CPU3");
    printf("   src = %s,  dst = %s\n",
           $port_names{$src_port} || sprintf("0x%04x", $src_port),
           $port_names{$orig_dst} || sprintf("0x%04x", $orig_dst));

    # Step 3: Show data words
    print "3. Packet data words:\n";
    my $show = ($pkt_word_cnt > 8) ? 8 : $pkt_word_cnt;
    for (my $i = 1; $i < $show; $i++) {
        my ($rc, $rh, $rl) = bram_read($i);
        printf("   BRAM[%d]: ctrl=0x%02x  data=0x%08x_%08x\n", $i, $rc, $rh, $rl);
    }
    if ($pkt_word_cnt > 8) {
        printf("   ... (%d more words)\n", $pkt_word_cnt - 8);
    }

    # Step 4: Determine dst_port
    my $new_dst;
    if (defined $dst_port_hex) {
        $new_dst = hex($dst_port_hex);
        printf("4. Using specified dst_port=0x%04x (%s)\n", $new_dst,
               $port_names{$new_dst} || "unknown");
    } else {
        if ($src_port == 0) {
            print "4. src_port=0x0000 (not set by output_port_lookup). Must specify dst_port.\n";
            print "   Usage: lab8reg packet_echo <dst_port_hex>\n";
            print "   Ports: 01=MAC0(node0) 04=MAC1(node1) 10=MAC2(node2) 40=MAC3(node3)\n";
            fifo_set_mode(0);
            return;
        }
        # Default: echo back to source MAC port
        $new_dst = $src_port;
        printf("4. No dst_port specified — echoing back to src_port=0x%04x (%s)\n",
               $new_dst, $port_names{$new_dst} || "unknown");
    }

    # Step 5: Rewrite header (PCI write with ctrl=0xFF)
    # dst_port is data[63:48] = upper 16 bits of $hhi
    my $new_hi = (($new_dst & 0xFFFF) << 16) | ($word_len & 0xFFFF);
    printf("5. Rewriting header: dst_port 0x%04x -> 0x%04x (ctrl=0xFF preserved)...\n",
           $orig_dst, $new_dst);
    bram_write(0, 0xFF, $new_hi, $hlo);
    my ($vc, $vh, $vl) = bram_read(0);
    printf("   Verify: ctrl=0x%02x  data=0x%08x_%08x\n", $vc, $vh, $vl);

    # Step 6: Drain
    print "6. Switching to FIFO mode and draining...\n";
    fifo_set_mode(0);
    fifo_drain();
    print "   Drain triggered.\n";

    printf("\n=== Packet Echo Complete ===\n");
    printf("Packet sent to %s.\n",
           $port_names{$new_dst} || sprintf("port 0x%04x", $new_dst));

}

