sub cmd_gpu_status {
    my $s = regread($GPU_STATUS_REG);
    my $kernel_done = $s & 1;
    my $dma_busy    = ($s >> 1) & 1;
    my $ctrl = regread($GPU_CTRL_REG);
    my $gpu_reset = $ctrl & 1;

    printf("GPU_STATUS = 0x%08x  GPU_CTRL = 0x%08x\n", $s, $ctrl);
    printf("  kernel_done=%d  dma_busy=%d  gpu_reset=%d\n",
           $kernel_done, $dma_busy, $gpu_reset);
}

sub cmd_gpu_reset {
    gpu_assert_reset();
    print "GPU held in reset.\n";
}

sub cmd_gpu_start {
    gpu_release_reset();
    print "GPU released from reset (executing).\n";
}

sub cmd_gpu_stop {
    gpu_assert_reset();
    print "GPU stopped (held in reset).\n";
}

sub cmd_gpu_load_imem {
    my ($filename) = @_;
    die "Usage: lab8reg gpu_load_imem <hex_file>\n" unless defined $filename;

    open(my $fh, '<', $filename) or die "Cannot open $filename: $!\n";

    # Hold GPU in reset while loading
    gpu_assert_reset();

    my $addr = 0;
    while (my $line = <$fh>) {
        chomp $line;
        $line =~ s/^\s+//;
        $line =~ s/\s+$//;
        next if $line eq '' || $line =~ /^\/\//;

        my $data = hex($line);
        gpu_write_imem($addr, $data);
        $addr++;
    }
    close($fh);

    printf("Loaded %d instructions from %s into GPU IMEM (GPU held in reset).\n",
           $addr, $filename);
}

sub cmd_gpu_read_imem {
    my ($start, $count) = @_;
    $start = 0 unless defined $start;
    $count = 16 unless defined $count;

    for (my $i = $start; $i < $start + $count; $i++) {
        my $data = gpu_read_imem($i);
        printf("GPU IMEM[%3d]: 0x%08x\n", $i, $data);
    }
}

sub cmd_gpu_read_dmem {
    my ($start, $count) = @_;
    $start = 0 unless defined $start;
    $count = 8 unless defined $count;

    for (my $i = $start; $i < $start + $count; $i++) {
        my ($hi, $lo) = gpu_read_dmem($i);
        printf("GPU DMEM[%3d]: 0x%08x_%08x\n", $i, $hi, $lo);
    }
}

sub cmd_gpu_write_dmem {
    my ($addr, $hi_hex, $lo_hex) = @_;
    die "Usage: lab8reg gpu_write_dmem <addr> <data_hi_hex> <data_lo_hex>\n"
        unless defined $addr && defined $hi_hex && defined $lo_hex;

    my $hi = hex($hi_hex);
    my $lo = hex($lo_hex);

    gpu_write_dmem($addr + 0, $hi, $lo);
    printf("GPU DMEM[%3d] <= 0x%08x_%08x\n", $addr + 0, $hi, $lo);

    # Read back
    my ($rhi, $rlo) = gpu_read_dmem($addr + 0);
    printf("Readback:       0x%08x_%08x\n", $rhi, $rlo);
}

