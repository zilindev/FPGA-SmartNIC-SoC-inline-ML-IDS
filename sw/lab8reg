# Commands — Integration test (GPU + DMA)
# ============================================================================

sub cmd_gpu_test {
    my ($filename) = @_;
    die "Usage: lab8reg gpu_test <hex_file>\n" .
        "  Full GPU-DMA test: inject packet, DMA to GPU, run kernel, DMA back,\n" .
        "  verify results. Use HALT-only hex for passthrough test.\n"
        unless defined $filename;

    print "=== GPU-DMA Integration Test ===\n\n";

    # Step 1: Reset GPU only (keep FIFO packet intact)
    print "1. Reset GPU...\n";
    gpu_assert_reset();

    # Step 2: Check for packet in FIFO
    print "2. Checking for packet...\n";
    my $s = regread($STATUS_REG);
    my $pkt_ready = $s & 1;
    my $pkt_word_cnt = ($s >> 24) & 0xFF;
    if (!$pkt_ready) {
        print "   No packet in FIFO. Send a packet first, then retry.\n";
        return;
    }
    printf("   Packet ready: %d words\n", $pkt_word_cnt);

    # Step 3: Switch to GPU mode
    print "3. Setting mode=GPU...\n";
    fifo_set_mode(2);

    # Step 4: Load GPU IMEM
    print "4. Loading GPU IMEM from $filename...\n";
    open(my $fh, '<', $filename) or die "Cannot open $filename: $!\n";
    my $addr = 0;
    while (my $line = <$fh>) {
        chomp $line;
        $line =~ s/^\s+//;
        $line =~ s/\s+$//;
        next if $line eq '' || $line =~ /^\/\//;
        gpu_write_imem($addr, hex($line));
        $addr++;
    }
    close($fh);
    printf("   Loaded %d instructions.\n", $addr);

    # Step 5: DMA FIFO->GPU (skip header word 0, copy data words 1..N)
    my $data_words = $pkt_word_cnt - 1;   # exclude header
    printf("5. DMA FIFO->GPU: FIFO[1..%d] -> GPU DMEM[0..%d] (%d words)...\n",
           $pkt_word_cnt - 1, $data_words - 1, $data_words);
    if (!dma_transfer_and_wait(1, 0, $data_words, 0)) {
        print "   DMA failed!\n";
        return;
    }
    print "   DMA complete.\n";

    # Step 6: Verify GPU DMEM[0] (should match FIFO data word 1)
    print "6. Verifying GPU DMEM[0]...\n";
    my ($hi, $lo) = gpu_read_dmem(0);
    printf("   GPU DMEM[0] = 0x%08x_%08x\n", $hi, $lo);

    # Also show FIFO BRAM[1] for comparison
    my ($rctrl, $rhi, $rlo) = bram_read(1);
    printf("   FIFO BRAM[1] = 0x%08x_%08x (ctrl=0x%02x)\n", $rhi, $rlo, $rctrl);

    # Step 7: Run GPU kernel
    print "7. Running GPU kernel...\n";
    gpu_release_reset();

    # Poll kernel_done
    my $done = 0;
    for (my $i = 0; $i < 200; $i++) {
        $s = regread($GPU_STATUS_REG);
        if ($s & 1) {
            printf("   kernel_done after polling %d times\n", $i);
            $done = 1;
            last;
        }
        select(undef, undef, undef, 0.01);  # 10ms
    }
    if (!$done) {
        printf("   WARNING: kernel_done not set after 2s (GPU_STATUS=0x%08x)\n",
               regread($GPU_STATUS_REG));
    }

    # Re-assert GPU reset before DMA back
    gpu_assert_reset();

    # Step 8: Show GPU DMEM after kernel
    print "8. GPU DMEM after kernel:\n";
    for (my $i = 0; $i < $data_words && $i < 8; $i++) {
        ($hi, $lo) = gpu_read_dmem($i);
        printf("   DMEM[%d] = 0x%08x_%08x\n", $i, $hi, $lo);
    }

    # Step 9: DMA GPU->FIFO
    printf("9. DMA GPU->FIFO: GPU DMEM[0..%d] -> FIFO[1..%d]...\n",
           $data_words - 1, $pkt_word_cnt - 1);
    if (!dma_transfer_and_wait(1, 0, $data_words, 1)) {
        print "   DMA failed!\n";
        return;
    }
    print "   DMA complete.\n";

    # Step 10: Verify FIFO BRAM
    print "10. FIFO BRAM after round-trip:\n";
    for (my $i = 0; $i < $pkt_word_cnt && $i < 9; $i++) {
        ($rctrl, $rhi, $rlo) = bram_read($i);
        printf("    BRAM[%d]: ctrl=0x%02x data=0x%08x_%08x\n", $i, $rctrl, $rhi, $rlo);
    }

    # Step 11: Drain
    print "11. Switching to FIFO mode and draining...\n";
    fifo_set_mode(0);
    fifo_drain();
    print "    Drain triggered.\n";

    print "\n=== GPU-DMA Test Complete ===\n";
}

